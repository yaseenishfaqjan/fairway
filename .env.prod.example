# Fairway360 — production environment for docker-compose.prod.yml.
#   cp .env.prod.example .env   # then fill in the values below
#   docker compose -f docker-compose.prod.yml up -d --build
# The file named ".env" is what docker compose loads. Never commit it.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Your live domain (Caddy provisions HTTPS for it automatically).
DOMAIN=app.fairway360.io
# Postgres password for the bundled db service.
DB_PASSWORD=change_this_to_a_strong_password
# Signs the session cookie — long random string (>= 32 chars).
SESSION_SECRET=change_this_to_a_long_random_secret_at_least_32_chars

# ── AI (real concierge + channel agents) ─────────────────────────────────────
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-...paste-your-openai-key...
OPENAI_MODEL=gpt-4o-mini
# Model for the Kitchen order-taking flow (needs reliable tool-calling).
ORDER_MODEL=gpt-4o
# Optional backup provider (used automatically if OpenAI fails):
ANTHROPIC_API_KEY=
CONCIERGE_MODEL=claude-sonnet-4-5

# ── Email (Resend) — powers demo notifications + invites ─────────────────────
# Domain fairway360.io is already verified in Resend. Paste the API key here.
RESEND_API_KEY=re_...paste-your-resend-key...
EMAIL_FROM=Fairway360 <noreply@fairway360.io>
# All customer/demo enquiries are emailed here:
SALES_NOTIFY_EMAIL=info@fairway360.io

# ── Optional ─────────────────────────────────────────────────────────────────
# Stripe (member payments):
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Sentry (error monitoring):
SENTRY_DSN=
# Analytics id baked into the SPA at build time:
VITE_GA_ID=
