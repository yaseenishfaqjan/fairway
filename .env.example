# --- Database ---
# For production / docker, set a real Postgres connection string:
DATABASE_URL=postgres://fairway:password@postgres:5432/fairway360
# For local dev with no Postgres installed, leave DATABASE_URL unset and the
# server will use an embedded PGlite database stored here:
PGLITE_DATA_DIR=./.pgdata
DB_PASSWORD=strongpassword

# --- Auth ---
JWT_SECRET=change_this_to_64_char_random_string_aaaaaaaaaaaaaaaaaaaaaaaa
JWT_REFRESH_SECRET=change_this_to_different_64_char_string_bbbbbbbbbbbbbbbb
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

# --- Server ---
NODE_ENV=development
PORT=3001
CLIENT_URL=http://localhost:5173

# --- Client ---
VITE_API_URL=http://localhost:3001/api/v1
