# Fairway360 environment. Copy to .env and fill in. Never commit real secrets.
# Only the REQUIRED vars are needed to run; everything else is optional and the
# app degrades gracefully (safe fallbacks) when a key is absent.

# ── REQUIRED ─────────────────────────────────────────────────────────────────
# Postgres connection string (production / docker):
DATABASE_URL=postgres://fairway:password@postgres:5432/fairway360
# For local dev with no Postgres, leave DATABASE_URL unset to use embedded PGlite:
PGLITE_DATA_DIR=./.pgdata
# Signs the session cookie. Use a long random string (>= 32 chars).
SESSION_SECRET=change_this_to_a_long_random_string_at_least_32_chars
# Port the server listens on (production single-service also serves the SPA).
PORT=5000

# ── STRONGLY RECOMMENDED ─────────────────────────────────────────────────────
# Public base URL of the deployment — used to build invite / password-reset
# links in emails. Without it those links may not resolve for recipients.
APP_URL=https://app.yourdomain.com

# ── AI agents (concierge + per-department channel agents) ────────────────────
# Set at least one provider for real AI replies; with neither, agents use
# deterministic fallback replies (app still works). The code tries the preferred
# provider first and falls through to the other on any failure.
LLM_PROVIDER=openai            # "openai" (default) or "anthropic"
OPENAI_API_KEY=                # sk-...      https://platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini
# Model for the Kitchen order-taking flow (needs reliable tool-calling).
ORDER_MODEL=gpt-4o
ANTHROPIC_API_KEY=             # sk-ant-...  https://console.anthropic.com/settings/keys
CONCIERGE_MODEL=claude-sonnet-4-5

# ── Email (member/staff invites, password resets) — Resend ───────────────────
# Without these, invite links are logged to the server for the admin to share.
RESEND_API_KEY=
EMAIL_FROM=Fairway360 <noreply@yourdomain.com>
SALES_NOTIFY_EMAIL=

# ── SMS (Level-3 escalation alerts) — Twilio (optional) ──────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# ── Payments — Stripe (optional) ─────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Error monitoring — Sentry (optional) ─────────────────────────────────────
SENTRY_DSN=
